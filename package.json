{
  "name": "documentation-mapper",
  "private": true,
  "version": "0.2.6",
  "type": "module",
  "scripts": {
    "prebuild": "tsc -p tsconfig.app.json",
    "build": "tsc -p tsconfig.app.json && vite build",
    "postbuild": "mkdir -p dist/output && cp dist/plugin.js dist/output/ && cp dist/index.html dist/output/",
    "dev": "vite",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "prepare": "npm run build",
    "clean": "node -e \"import('fs').then(fs => fs.promises.rm('dist', { recursive: true, force: true }))\""
  },
  "dependencies": {
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.85.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/node": "^20.11.24",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^24.0.0",
    "lru-cache": "^10.2.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vite-plugin-singlefile": "^0.13.5",
    "vitest": "^1.6.0"
  }
}
